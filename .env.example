PORT=8080
HOST=0.0.0.0

# OpenClaw upstream base URL and path.
OPENCLAW_API_BASE_URL=https://your-openclaw-host.example.com
OPENCLAW_WIRE_API=chat_completions
OPENCLAW_CHAT_PATH=/chat/completions
OPENCLAW_RESPONSES_PATH=/responses

# Upstream auth modes:
# - bearer: Authorization: Bearer <token>
# - cookie: Cookie: <raw cookie>
OPENCLAW_AUTH_MODE=bearer
OPENCLAW_ACCESS_TOKEN=
OPENCLAW_COOKIE=

# Optional token refresh endpoint. If configured, the proxy retries once after 401.
OPENCLAW_REFRESH_URL=
OPENCLAW_REFRESH_METHOD=POST
OPENCLAW_REFRESH_HEADERS={"Content-Type":"application/json"}
OPENCLAW_REFRESH_BODY={"refresh_token":"replace_me"}
OPENCLAW_REFRESH_TOKEN_PATH=access_token

# Optional hard guard for inbound OpenAI key.
OPENAI_PROXY_API_KEY=
